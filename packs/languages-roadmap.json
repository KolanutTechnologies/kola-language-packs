  "uiDesignRoadmap": {
    "description": "Optional pack layer for Design-tab markup people read and edit. Phased catalog U1–U6 toward full encounter coverage (tags, props, components, Tailwind utility families). Human guide: ROADMAP.md UI/Design; TIERS.md UI/Design.",
    "status": "planned",
    "priority": "high",
    "productRule": "People-facing native gloss; reverse map / emit to English host. Learners will adjust class strings and tags by hand.",
    "catalogGoal": "Everything someone will encounter in Design mode and common manual edits, expanded over phases. Prefer stem families + composing scales over one pack row per p-0…p-96.",
    "notInScopeUntilLater": [
      "Raw CSS property authoring (margin-top: 1rem as source language)",
      "Open-ended arbitrary values as a free grammar ([17px])",
      "Every third-party Tailwind plugin",
      "logical-tokens.json keyword coverage",
      "Required for IDE-ready validation until U1 ships"
    ],
    "compositionModel": {
      "description": "How full catalog coverage stays maintainable",
      "stemPlusScale": "Gloss stem (P, FLEX_COL, SPACE_Y); keep numeric scale or palette token as host/shared (p-4, bg-red-500)",
      "prefixes": "State and responsive prefixes are separate keys from U5 (hover, md, dark)",
      "openQuestion": "Per-family: translate full token vs stem-only (decide in U1 design notes)"
    },
    "catalogPhases": [
      {
        "id": "U1",
        "name": "Schema + Design-tab encounter set",
