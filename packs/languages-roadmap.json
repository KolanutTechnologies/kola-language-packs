  "ideTierRoadmap": {
    "description": "Optional glossary, placeholders, and commonLiterals for IDE-ready packs. Seed keys in ide-tier-seeds.json.",
    "learnModeGlossSchedule": {
      "description": "When English left in Learn mode is by design vs a pack gap. Human guide: ROADMAP.md Learn-mode gloss schedule; TIERS.md Learn mode section.",
      "level1KeywordsOnly": "Learn L1 swaps reserved keywords. Identifiers and string literals stay English until glossary / commonLiterals / IDE symbols.",
      "englishOnlyKeywordStubs": {
        "layer": "keywords",
        "examples": [
          "IN",
          "RANGE"
        ],
        "when": "any-patch",
        "note": "Fill when native wording is reviewed. Not blocked on a minor IDE batch. Many packs still ship IN as [\"in\"]."
      },
      "identifiers": {
        "layer": "glossary",
        "examples": [
          "out",
          "i",
          "str"
        ],
        "when": "patch-anytime-or-0.34.0-seed-expansion",
        "note": "L1 leaving out English is by design. Add glossary keys as patches; expand seed lists at 0.34.0. Project-specific names are IDE symbols, not this package."
      },
      "exampleStrings": {
        "layer": "commonLiterals",
        "examples": [
          "FizzBuzz",
          "Hello"
        ],
        "when": "0.34.0-seed-expansion"
      },
      "designTabComponents": {
        "layer": "uiDesign",
        "examples": [
          "Button",
          "div",
          "className",
          "flex",
          "flex-col",
          "p-4",
          "Alert"
        ],
        "when": "U1-at-0.37.0-then-U2-U6",
        "note": "Phased full encounter catalog. People read native; IDE emits English/host. Stem families + compose scales."
      },
      "eventsA11yAndTestDsl": {
        "layer": "phase-f",
        "examples": [
          "onClick",
          "aria-label",
          "describe",
          "expect"
        ],
        "when": "2.1.0-phase-f",
        "note": "See futureMappingCandidates. After UI/Design U1 and builtins foundations."
      },
      "stdlibBuiltinCalls": {
        "layer": "stdlib-builtins",
        "examples": [
          "len",
          "python range()"
        ],
        "when": "2.0.0",
        "note": "Logical RANGE is mainly Go range keyword; Python range() is closer to builtins."
      }
    },
